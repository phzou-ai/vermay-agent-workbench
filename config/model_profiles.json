{
  "default_profile": "ollama_default",
  "profiles": {
    "ollama_default": {
      "provider": "ollama",
      "options": {}
    },
    "openai_compatible_example": {
      "provider": "openai_compatible",
      "options": {
        "model": "qwen",
        "base_url": "http://localhost:8000/v1",
        "timeout_seconds": "120"
      }
    }
  },
  "rules": [
    {
      "profile": "openai_compatible_example",
      "contains": ["long context", "large model"]
    },
    {
      "profile": "ollama_default",
      "on_tool_error": true
    }
  ]
}
